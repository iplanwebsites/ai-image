# OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Replicate API Token
# Get yours at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here

# Stability AI API Key
# Get yours at: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_stability_api_key_here

# FAL.ai API Key
# Get yours at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Together AI API Key
# Get yours at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# Black Forest Labs (BFL) API Key
# Get yours at: https://api.bfl.ml/auth/login
BFL_API_KEY=your_bfl_api_key_here

# Google API Key (for Imagen via Gemini API)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Fireworks AI API Key
# Get yours at: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Ollama runs locally — no API key needed
# Install from: https://ollama.com
# Pass a custom host with --api-key http://hostname:11434
